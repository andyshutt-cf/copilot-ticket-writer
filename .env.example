# Jira Integration — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control (it is already in .gitignore).

# Your Jira instance URL (include the trailing slash or omit — both work)
JIRA_BASE_URL=https://yourorg.atlassian.net

# The email address associated with your Jira account
JIRA_EMAIL=your.email@yourorg.com

# A Jira API token (not your password).
# Generate one at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token-here

# The default Jira project key to create issues in (e.g. ACME, PLATFORM, BE)
# This can be overridden per-run with the --project flag.
JIRA_PROJECT_KEY=PROJ
