{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Create Jira Ticket from File",
      "type": "shell",
      "command": "node scripts/create-jira-ticket.js --file \"${input:ticketFile}\"",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Create Jira Ticket (dry run)",
      "type": "shell",
      "command": "node scripts/create-jira-ticket.js --file \"${input:ticketFile}\" --dry-run",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "ticketFile",
      "description": "Path to the Markdown ticket file (e.g. ticket.md)",
      "default": "ticket.md",
      "type": "promptString"
    }
  ]
}
